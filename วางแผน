<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>RO Guild War — Tactical Board</title>
<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%;background:#080b14;color:#e8d5a3;font-family:'Inter',sans-serif;overflow:hidden}

.app{display:flex;height:100vh;overflow:hidden}

/* SIDEBAR */
.sidebar{width:230px;min-width:230px;background:#0b0e1a;border-right:1px solid #1e1a30;display:flex;flex-direction:column;overflow:hidden;z-index:10}
.sidebar-top{padding:14px 14px 10px;border-bottom:1px solid #1e1a30;background:#07090f}
.app-logo{font-family:'Cinzel',serif;font-size:13px;font-weight:700;color:#c9960c;letter-spacing:1.5px}
.app-sub{font-size:9px;color:#3a3454;letter-spacing:2px;text-transform:uppercase;margin-top:2px}
.party-list{flex:1;overflow-y:auto;padding:8px;display:flex;flex-direction:column;gap:5px}
.party-list::-webkit-scrollbar{width:3px}
.party-list::-webkit-scrollbar-thumb{background:#2a2040;border-radius:2px}

.pcard{background:#0f1220;border:1px solid #1e1a30;border-radius:9px;padding:9px 10px;cursor:default;transition:border-color .15s,background .15s}
.pcard:hover{border-color:#c9960c44}
.pcard.selected{border-color:#c9960c;background:#141220}
.pcard-top{display:flex;align-items:center;gap:8px;margin-bottom:6px}

/* TOKEN ทึบขึ้น - solid bg */
.pavatar{width:30px;height:30px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;font-family:'Cinzel',serif;flex-shrink:0;border:2px solid;cursor:grab}
.pinfo{flex:1;min-width:0}
.pname-input{background:transparent;border:none;outline:none;color:#e8d5a3;font-size:12px;font-weight:600;font-family:'Cinzel',serif;width:100%;padding:0}
.role-select{background:#080b14;border:1px solid #2a2040;border-radius:4px;color:#8a7898;font-size:9px;font-family:'Inter',sans-serif;padding:2px 4px;outline:none;cursor:pointer;margin-top:2px;width:100%}
.role-select:focus{border-color:#c9960c55}
.pnote-input{background:#080b14;border:1px solid #1a1428;border-radius:5px;color:#7a6890;font-size:10px;font-family:'Inter',sans-serif;width:100%;padding:5px 7px;outline:none;resize:none;transition:border-color .15s;line-height:1.4}
.pnote-input:focus{border-color:#c9960c44;color:#a090b0}
.pnote-input::placeholder{color:#2a2040;font-style:italic}
.member-list{margin-top:6px;display:flex;flex-direction:column;gap:3px}
.member-row{display:flex;align-items:center;gap:5px}
.member-num{font-size:9px;color:#3a3050;width:12px;flex-shrink:0;font-family:'Cinzel',serif}
.member-input{background:transparent;border:none;border-bottom:1px solid #1a1428;outline:none;color:#7a6890;font-size:10px;font-family:'Inter',sans-serif;flex:1;padding:2px 3px;transition:border-color .15s}
.member-input:focus{border-color:#c9960c44;color:#a090b0}
.member-input::placeholder{color:#2a2040}
.pcard-toggle{font-size:9px;color:#3a3050;cursor:pointer;text-align:right;margin-top:5px;padding:1px 3px;border-radius:3px;transition:color .15s;user-select:none}
.pcard-toggle:hover{color:#7a6890}

/* MAP */
.map-wrap{flex:1;position:relative;overflow:hidden;background:#050710}
.toolbar{position:absolute;top:10px;left:50%;transform:translateX(-50%);display:flex;align-items:center;gap:6px;background:#0b0e1aee;border:1px solid #1e1a30;border-radius:9px;padding:6px 8px;z-index:30}
.tb-btn{padding:5px 14px;font-size:10px;font-family:'Cinzel',serif;font-weight:600;letter-spacing:.5px;border-radius:6px;border:1px solid transparent;cursor:pointer;color:#5a5070;background:transparent;transition:all .15s}
.tb-btn:hover{color:#e8d5a3;background:#1a1830}
.tb-btn.active{background:#c9960c1a;border-color:#c9960c55;color:#c9960c}
.tb-sep{width:1px;height:20px;background:#1e1a30}
.tool-btn{padding:5px 9px;font-size:14px;border-radius:6px;border:1px solid transparent;cursor:pointer;color:#5a5070;background:transparent;transition:all .15s;line-height:1;font-family:'Inter',sans-serif}
.tool-btn:hover{color:#e8d5a3;background:#1a1830}
.tool-btn.active{background:#c9960c1a;border-color:#c9960c55;color:#c9960c}

.map-stage{width:100%;height:100%;position:relative}
.map-img{position:absolute;inset:0;width:100%;height:100%;object-fit:contain;pointer-events:none;user-select:none}

/* PARTY TOKEN — ทึบ solid ไม่ใส */
.party-token{
  position:absolute;width:48px;height:48px;border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  font-size:13px;font-weight:700;font-family:'Cinzel',serif;
  cursor:grab;z-index:15;user-select:none;
  transform:translate(-50%,-50%);
  flex-direction:column;gap:0;
  box-shadow:0 2px 12px #000a, 0 0 0 3px #000;
}
.party-token:hover{filter:brightness(1.2);z-index:20}
.party-token.dragging{cursor:grabbing;z-index:50;filter:brightness(1.3)}
.party-token.line-selected{box-shadow:0 2px 12px #000a,0 0 0 3px #fff6}
.tok-label{
  position:absolute;bottom:-20px;left:50%;transform:translateX(-50%);
  font-size:9px;white-space:nowrap;color:#fff;
  font-family:'Cinzel',serif;font-weight:600;
  text-shadow:0 1px 4px #000,0 0 8px #000,0 0 16px #000;
  letter-spacing:.3px;pointer-events:none;
  background:#000a;padding:1px 4px;border-radius:3px;
}
.tok-num{font-size:14px;line-height:1;pointer-events:none;text-shadow:0 1px 3px #000}

/* SVG ARROW LAYER */
.arrow-layer{position:absolute;inset:0;width:100%;height:100%;z-index:8}

/* RIGHT PANEL */
.right-panel{width:200px;min-width:200px;background:#0b0e1a;border-left:1px solid #1e1a30;display:flex;flex-direction:column;overflow:hidden}
.rpanel-sec{padding:12px 14px;border-bottom:1px solid #1e1a30}
.sec-label{font-size:9px;text-transform:uppercase;letter-spacing:2px;color:#c9960c;font-family:'Cinzel',serif;font-weight:600;margin-bottom:8px}
.legend-row{display:flex;align-items:center;gap:7px;margin-bottom:4px}
.leg-dot{width:22px;height:22px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:9px;font-family:'Cinzel',serif;font-weight:700;border:2px solid;flex-shrink:0}
.leg-name{font-size:11px;color:#9090a0;font-family:'Inter',sans-serif;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.obj-row{display:flex;align-items:center;gap:6px;margin-bottom:4px;font-size:10px;color:#5a5070;font-family:'Inter',sans-serif}
.obj-dot{width:10px;height:10px;border-radius:2px;flex-shrink:0}
.battle-notes-area{flex:1;padding:12px 14px;display:flex;flex-direction:column;min-height:0}
.notes-ta{flex:1;background:#07090f;border:1px solid #1e1a30;border-radius:6px;color:#8a7898;font-size:10px;font-family:'Inter',sans-serif;line-height:1.5;padding:8px;resize:none;outline:none;transition:border-color .15s;min-height:60px}
.notes-ta:focus{border-color:#c9960c44}
.notes-ta::placeholder{color:#2a2040;font-style:italic}
.plans-section{padding:10px 14px;border-top:1px solid #1e1a30;border-bottom:1px solid #1e1a30}
.plan-row{display:flex;gap:4px;margin-bottom:6px}
.plan-input{flex:1;background:#07090f;border:1px solid #1e1a30;border-radius:5px;color:#a090b0;font-size:10px;padding:4px 7px;outline:none;font-family:'Inter',sans-serif}
.plan-input:focus{border-color:#c9960c44}
.save-btn{padding:4px 8px;background:#c9960c1a;border:1px solid #c9960c44;border-radius:5px;color:#c9960c;font-size:10px;cursor:pointer;font-family:'Cinzel',serif;font-weight:600;transition:all .15s;white-space:nowrap}
.save-btn:hover{background:#c9960c33}
.saved-plans{display:flex;flex-direction:column;gap:3px;max-height:80px;overflow-y:auto}
.saved-plans::-webkit-scrollbar{width:3px}
.saved-plans::-webkit-scrollbar-thumb{background:#2a2040}
.plan-item{display:flex;align-items:center;justify-content:space-between;padding:4px 7px;background:#0f1220;border:1px solid #1e1a30;border-radius:5px;cursor:pointer;transition:border-color .15s}
.plan-item:hover{border-color:#c9960c44}
.plan-item-name{font-size:10px;font-family:'Cinzel',serif;color:#8a7898}
.plan-del{font-size:10px;color:#3a3050;cursor:pointer;padding:0 2px;transition:color .15s}
.plan-del:hover{color:#e24b4a}
.bottom-btns{padding:10px 14px;display:flex;flex-direction:column;gap:5px}
.act-btn{padding:7px 10px;border-radius:6px;border:1px solid;cursor:pointer;font-size:10px;font-family:'Cinzel',serif;font-weight:600;letter-spacing:.5px;transition:all .15s;text-align:center}
.btn-primary{background:#c9960c1a;border-color:#c9960c55;color:#c9960c}
.btn-primary:hover{background:#c9960c2a;border-color:#c9960c88}
.btn-ghost{background:transparent;border-color:#1e1a30;color:#5a5070}
.btn-ghost:hover{border-color:#3a3050;color:#8a7898}
.btn-danger{background:transparent;border-color:#1e1a30;color:#5a5070}
.btn-danger:hover{border-color:#e24b4a44;color:#e24b4a88}

/* DRAW COLOR PICKER */
.color-row{display:flex;gap:5px;align-items:center;padding:4px 0}
.color-swatch{width:18px;height:18px;border-radius:50%;cursor:pointer;border:2px solid transparent;transition:border-color .15s;flex-shrink:0}
.color-swatch.active{border-color:#fff}

/* TOOLTIP */
.tok-tooltip{position:fixed;background:#0b0e1aee;border:1px solid #c9960c55;border-radius:7px;padding:8px 10px;font-size:10px;font-family:'Inter',sans-serif;color:#a090b0;z-index:200;pointer-events:none;min-width:120px;max-width:180px;line-height:1.5;display:none}
.tok-tooltip-name{font-family:'Cinzel',serif;font-size:11px;color:#c9960c;font-weight:600;margin-bottom:3px}

/* SELECTED LINE INDICATOR */
.line-info{position:absolute;bottom:10px;left:50%;transform:translateX(-50%);background:#0b0e1aee;border:1px solid #c9960c55;border-radius:6px;padding:5px 12px;font-size:10px;font-family:'Inter',sans-serif;color:#c9960c;z-index:30;display:none}
</style>
</head>
<body>
<div class="app" id="app">

<div class="sidebar">
  <div class="sidebar-top">
    <div class="app-logo">⚔ GUILD WAR BOARD</div>
    <div class="app-sub">Ragnarok Origin · Tactical</div>
  </div>
  <div class="party-list" id="partyList"></div>
</div>

<div class="map-wrap">
  <div class="toolbar">
    <button class="tb-btn active" id="btn-stellar" onclick="switchMap('stellar')">Stellar Clash</button>
    <button class="tb-btn" id="btn-vale" onclick="switchMap('vale')">Vale of Clash</button>
    <div class="tb-sep"></div>
    <button class="tool-btn active" id="tool-select" title="Select / Move" onclick="setTool('select')">↖</button>
    <button class="tool-btn" id="tool-arrow" title="Draw Arrow" onclick="setTool('arrow')">➜</button>
    <button class="tool-btn" id="tool-line" title="Draw Line" onclick="setTool('line')">╱</button>
    <button class="tool-btn" id="tool-erase" title="Delete selected / Clear all" onclick="deleteSelected()">⌫</button>
    <div class="tb-sep"></div>
    <div class="color-row" id="colorRow"></div>
  </div>

  <div class="map-stage" id="mapStage">
    <img class="map-img" id="mapImg" src="" alt="map" draggable="false">
    <svg class="arrow-layer" id="arrowLayer"
      onmousedown="svgMouseDown(event)"
      onmousemove="svgMouseMove(event)"
      onmouseup="svgMouseUp(event)"></svg>
  </div>

  <div class="line-info" id="lineInfo">Click line to select · Drag endpoints to move · ⌫ to delete</div>
</div>

<div class="right-panel">
  <div class="rpanel-sec">
    <div class="sec-label">Legend</div>
    <div id="legendList"></div>
  </div>
  <div class="rpanel-sec">
    <div class="sec-label">Map Objects</div>
    <div id="objList"></div>
  </div>
  <div class="battle-notes-area">
    <div class="sec-label">Battle Notes</div>
    <textarea class="notes-ta" id="battleNotes" placeholder="เขียน notes กลยุทธ์...&#10;&#10;เช่น P1 hold crystal&#10;P3+P4 rush north"></textarea>
  </div>
  <div class="plans-section">
    <div class="sec-label">Saved Plans</div>
    <div class="plan-row">
      <input type="text" class="plan-input" id="planNameInput" placeholder="Plan name...">
      <button class="save-btn" onclick="savePlan()">Save</button>
    </div>
    <div class="saved-plans" id="savedPlans"></div>
  </div>
  <div class="bottom-btns">
    <div class="act-btn btn-primary" onclick="exportPlan()">⬡ Export Plan</div>
    <div class="act-btn btn-ghost" onclick="resetPositions()">Reset Positions</div>
    <div class="act-btn btn-danger" onclick="clearAll()">Clear All</div>
  </div>
</div>

<div class="tok-tooltip" id="tokTooltip"></div>
</div>

<script>
const STELLAR_IMG = "data:image/jpeg;base64,";
const VALE_IMG = "data:image/jpeg;base64,";

/* ---- PARTY COLORS solid (ไม่ใส) ---- */
const COLORS = [
  {solidBg:"#b8860b", border:"#ffd700", text:"#fff", lightBg:"#b8860b"},
  {solidBg:"#0e7a5a", border:"#5dcaa5", text:"#fff", lightBg:"#0e7a5a"},
  {solidBg:"#9b2020", border:"#e24b4a", text:"#fff", lightBg:"#9b2020"},
  {solidBg:"#3d2fa0", border:"#7f77dd", text:"#fff", lightBg:"#3d2fa0"},
  {solidBg:"#8b2252", border:"#d4537e", text:"#fff", lightBg:"#8b2252"},
  {solidBg:"#8a5c00", border:"#ef9f27", text:"#fff", lightBg:"#8a5c00"},
  {solidBg:"#124e8a", border:"#378add", text:"#fff", lightBg:"#124e8a"},
  {solidBg:"#2d6b1a", border:"#97c459", text:"#fff", lightBg:"#2d6b1a"},
];
const ROLES = ["Assault","Defense","Support","Roam","Sniper","Buffer","Healer","Tank"];
const ROLE_C = {Assault:"#e24b4a",Defense:"#378add",Support:"#5dcaa5",Roam:"#7f77dd",Sniper:"#ef9f27",Buffer:"#c9960c",Healer:"#97c459",Tank:"#888"};

const STELLAR_POS = [{x:18,y:28},{x:50,y:18},{x:82,y:28},{x:22,y:55},{x:78,y:55},{x:18,y:75},{x:50,y:82},{x:82,y:75}];
const VALE_POS    = [{x:22,y:18},{x:78,y:18},{x:22,y:42},{x:78,y:42},{x:22,y:72},{x:78,y:72},{x:50,y:30},{x:50,y:65}];

const DRAW_COLORS = ["#ffd700","#e24b4a","#5dcaa5","#7f77dd","#ef9f27","#fff"];
let activeDrawColor = "#ffd700";

let currentMap = "stellar";
let currentTool = "select";
let dragging = null, dragOX = 0, dragOY = 0;
let drawLines = [];   /* {type,x1%,y1%,x2%,y2%,color} */
let selectedLine = null;
let dragLine = null;  /* {lineIdx, endpoint:'start'|'end'|'mid', startX,startY,ox,oy} */
let drawing = false, drawStartPct = null;
let plans = {};
let expanded = {};

const parties = Array.from({length:8}, (_,i) => ({
  id:i+1, name:`Party ${i+1}`, role:ROLES[i]||"Assault",
  note:"", members:["","","","",""],
  x:STELLAR_POS[i].x, y:STELLAR_POS[i].y, color:COLORS[i],
}));

/* ========== COLOR PICKER ========== */
function renderColorPicker() {
  const el = document.getElementById("colorRow");
  el.innerHTML = DRAW_COLORS.map(c =>
    `<div class="color-swatch ${c===activeDrawColor?'active':''}" style="background:${c}" onclick="setDrawColor('${c}')" title="${c}"></div>`
  ).join("");
}
function setDrawColor(c) { activeDrawColor = c; renderColorPicker(); }

/* ========== SIDEBAR ========== */
function renderSidebar() {
  const el = document.getElementById("partyList");
  el.innerHTML = "";
  parties.forEach(p => {
    const rc = ROLE_C[p.role]||"#c9960c";
    const exp = expanded[p.id];
    const div = document.createElement("div");
    div.className = "pcard" + (p.selected?" selected":"");
    div.dataset.id = p.id;
    div.innerHTML = `
      <div class="pcard-top">
        <div class="pavatar" style="background:${p.color.solidBg};border-color:${p.color.border};color:${p.color.text}" title="P${p.id}">P${p.id}</div>
        <div class="pinfo">
          <input class="pname-input" value="${p.name}" oninput="updatePartyName(${p.id},this.value)">
          <select class="role-select" onchange="updateRole(${p.id},this.value)">
            ${ROLES.map(r=>`<option value="${r}" ${r===p.role?"selected":""}>   ${r}</option>`).join("")}
          </select>
        </div>
      </div>
      <textarea class="pnote-input" rows="2" placeholder="Tactic / objective..." oninput="updateNote(${p.id},this.value)">${p.note}</textarea>
      <div class="pcard-toggle" onclick="toggleExpand(${p.id})">${exp?"▲ hide members":"▼ show members"}</div>
      ${exp?`<div class="member-list">${p.members.map((m,mi)=>`
        <div class="member-row">
          <span class="member-num">${mi+1}</span>
          <input class="member-input" value="${m}" placeholder="Player name" oninput="updateMember(${p.id},${mi},this.value)">
        </div>`).join("")}</div>`:"" }
    `;
    el.appendChild(div);
  });
}
function toggleExpand(id) { expanded[id]=!expanded[id]; renderSidebar(); }
function updatePartyName(id,v) { parties[id-1].name=v; renderLegend(); updateTokenLabel(id); }
function updateRole(id,v) { parties[id-1].role=v; }
function updateNote(id,v) { parties[id-1].note=v; }
function updateMember(id,mi,v) { parties[id-1].members[mi]=v; }

function renderLegend() {
  document.getElementById("legendList").innerHTML = parties.map(p=>`
    <div class="legend-row">
      <div class="leg-dot" style="background:${p.color.solidBg};border-color:${p.color.border};color:#fff">${p.id}</div>
      <span class="leg-name">${p.name}</span>
    </div>`).join("");
}

function renderObjects() {
  const el = document.getElementById("objList");
  if (currentMap==="stellar") {
    el.innerHTML = `
      <div class="obj-row"><div class="obj-dot" style="background:#c9960c;border-radius:50%"></div>Sun Altar</div>
      <div class="obj-row"><div class="obj-dot" style="background:#7f77dd;border-radius:50%"></div>Moon Crystal</div>
      <div class="obj-row"><div class="obj-dot" style="background:#5dcaa5;border-radius:50%"></div>Star Shrine</div>
      <div class="obj-row"><div class="obj-dot" style="background:#fff5;border-radius:50%"></div>Celestial Core</div>`;
  } else {
    el.innerHTML = `
      <div class="obj-row"><div class="obj-dot" style="background:#c9960c;border-radius:50%"></div>Trophy (Center)</div>
      <div class="obj-row"><div class="obj-dot" style="background:#e24b4a"></div>Team Base ×2</div>
      <div class="obj-row"><div class="obj-dot" style="background:#7f77dd;border-radius:50%"></div>Statue Post ×4</div>
      <div class="obj-row"><div class="obj-dot" style="background:#378add;border-radius:50%"></div>Crystal ×2</div>`;
  }
}

/* ========== MAP SWITCH ========== */
function switchMap(mode) {
  currentMap = mode;
  document.getElementById("btn-stellar").classList.toggle("active", mode==="stellar");
  document.getElementById("btn-vale").classList.toggle("active", mode==="vale");
  document.getElementById("mapImg").src = mode==="stellar" ? STELLAR_IMG : VALE_IMG;
  const pos = mode==="stellar" ? STELLAR_POS : VALE_POS;
  parties.forEach((p,i) => { p.x=pos[i].x; p.y=pos[i].y; });
  drawLines=[]; selectedLine=null;
  renderSVG(); renderTokens(); renderObjects();
}

/* ========== TOKENS ========== */
function renderTokens() {
  document.querySelectorAll(".party-token").forEach(e=>e.remove());
  const stage = document.getElementById("mapStage");
  const W=stage.offsetWidth, H=stage.offsetHeight;
  parties.forEach(p => {
    const tok = document.createElement("div");
    tok.className = "party-token";
    tok.dataset.id = p.id;
    tok.style.cssText = `background:${p.color.solidBg};border:3px solid ${p.color.border};color:#fff;left:${p.x/100*W}px;top:${p.y/100*H}px`;
    tok.innerHTML = `<span class="tok-num">P${p.id}</span><span class="tok-label">${p.name}</span>`;
    tok.addEventListener("mousedown", startDragToken);
    tok.addEventListener("touchstart", startDragTokenT, {passive:false});
    tok.addEventListener("mouseenter", showTooltip);
    tok.addEventListener("mouseleave", hideTooltip);
    stage.appendChild(tok);
  });
}
function updateTokenLabel(id) {
  const tok = document.querySelector(`.party-token[data-id="${id}"]`);
  if (tok) tok.querySelector(".tok-label").textContent = parties[id-1].name;
}

/* ========== DRAG TOKENS ========== */
function startDragToken(e) {
  if (currentTool!=="select") return;
  e.preventDefault(); e.stopPropagation();
  const id = parseInt(e.currentTarget.dataset.id);
  dragging = id;
  e.currentTarget.classList.add("dragging");
  const stage=document.getElementById("mapStage"), r=stage.getBoundingClientRect();
  dragOX = e.clientX - r.left - parties[id-1].x/100*stage.offsetWidth;
  dragOY = e.clientY - r.top  - parties[id-1].y/100*stage.offsetHeight;
  document.addEventListener("mousemove", onDragToken);
  document.addEventListener("mouseup", stopDragToken);
}
function startDragTokenT(e) {
  if (currentTool!=="select") return;
  e.preventDefault(); e.stopPropagation();
  const id = parseInt(e.currentTarget.dataset.id);
  dragging=id; e.currentTarget.classList.add("dragging");
  const stage=document.getElementById("mapStage"), r=stage.getBoundingClientRect(), t=e.touches[0];
  dragOX=t.clientX-r.left-parties[id-1].x/100*stage.offsetWidth;
  dragOY=t.clientY-r.top -parties[id-1].y/100*stage.offsetHeight;
  document.addEventListener("touchmove",onDragTokenT,{passive:false});
  document.addEventListener("touchend",stopDragToken);
}
function moveToken(cx,cy) {
  const stage=document.getElementById("mapStage"), r=stage.getBoundingClientRect();
  let x=Math.max(2,Math.min(98,(cx-r.left-dragOX)/stage.offsetWidth*100));
  let y=Math.max(2,Math.min(98,(cy-r.top-dragOY)/stage.offsetHeight*100));
  parties[dragging-1].x=x; parties[dragging-1].y=y;
  const tok=document.querySelector(`.party-token[data-id="${dragging}"]`);
  if(tok){ tok.style.left=x/100*stage.offsetWidth+"px"; tok.style.top=y/100*stage.offsetHeight+"px"; }
}
function onDragToken(e) { if(dragging) moveToken(e.clientX,e.clientY); }
function onDragTokenT(e) { e.preventDefault(); if(dragging) moveToken(e.touches[0].clientX,e.touches[0].clientY); }
function stopDragToken() {
  if(dragging) { document.querySelector(`.party-token[data-id="${dragging}"]`)?.classList.remove("dragging"); dragging=null; }
  document.removeEventListener("mousemove",onDragToken);
  document.removeEventListener("mouseup",stopDragToken);
  document.removeEventListener("touchmove",onDragTokenT);
  document.removeEventListener("touchend",stopDragToken);
}

/* ========== TOOLTIP ========== */
function showTooltip(e) {
  const id=parseInt(e.currentTarget.dataset.id), p=parties[id-1];
  const tt=document.getElementById("tokTooltip");
  const rc=ROLE_C[p.role]||"#c9960c";
  const mems=p.members.filter(m=>m.trim());
  tt.innerHTML=`<div class="tok-tooltip-name">P${p.id} · ${p.name}</div>
    <div style="color:${rc};font-size:9px;margin-bottom:4px">${p.role}</div>
    ${p.note?`<div style="color:#8a7898;font-size:10px;margin-bottom:4px">${p.note}</div>`:""}
    ${mems.length?`<div style="color:#5a5070;font-size:9px">${mems.map((m,i)=>`${i+1}. ${m}`).join(" · ")}</div>`:""}`;
  tt.style.display="block";
  tt.style.left=(e.clientX+14)+"px";
  tt.style.top=(e.clientY-10)+"px";
}
function hideTooltip() { document.getElementById("tokTooltip").style.display="none"; }

/* ========== TOOL SELECT ========== */
function setTool(t) {
  currentTool=t;
  ["arrow","line","select"].forEach(n => document.getElementById("tool-"+n)?.classList.toggle("active",n===t));
  const stage=document.getElementById("mapStage");
  stage.style.cursor = t==="select"?"default":"crosshair";
  if(t==="select") deselectLine();
}

/* ========== SVG DRAW — lines & arrows with move support ========== */
const HIT = 10; /* hit-test radius px */
const HANDLE_R = 7;

function pctToXY(pct, W, H) { return {x:pct.x/100*W, y:pct.y/100*H}; }
function xyToPct(x, y, W, H) { return {x:Math.max(0,Math.min(100,x/W*100)), y:Math.max(0,Math.min(100,y/H*100))}; }

function getSVGSize() {
  const svg=document.getElementById("arrowLayer");
  return {W:svg.clientWidth||svg.parentElement.offsetWidth, H:svg.clientHeight||svg.parentElement.offsetHeight};
}
function clientToSVG(cx,cy) {
  const svg=document.getElementById("arrowLayer"), r=svg.getBoundingClientRect();
  return {x:cx-r.left, y:cy-r.top};
}

function renderSVG() {
  const svg=document.getElementById("arrowLayer");
  const {W,H}=getSVGSize();
  let out = `<defs>
    ${DRAW_COLORS.map(c=>`
      <marker id="ah-${c.replace('#','')}" markerWidth="10" markerHeight="10" refX="8" refY="4" orient="auto">
        <path d="M0,0 L0,8 L10,4 z" fill="${c}" opacity="0.95"/>
      </marker>`).join("")}
  </defs>`;

  drawLines.forEach((l,i) => {
    const p1=pctToXY({x:l.x1,y:l.y1},W,H), p2=pctToXY({x:l.x2,y:l.y2},W,H);
    const isSel = selectedLine===i;
    const dash = l.type==="line"?"stroke-dasharray='10,6'":"";
    const marker = l.type==="arrow"?`marker-end="url(#ah-${l.color.replace('#','')})"`:"";
    const glow = isSel?`filter="url(#sel-glow)"`:"";

    /* fat invisible hit area */
    out += `<line x1="${p1.x}" y1="${p1.y}" x2="${p2.x}" y2="${p2.y}"
      stroke="transparent" stroke-width="18" style="cursor:pointer"
      data-line="${i}" class="line-hit"/>`;

    /* visible line */
    out += `<line x1="${p1.x}" y1="${p1.y}" x2="${p2.x}" y2="${p2.y}"
      stroke="${l.color}" stroke-width="${isSel?5:3.5}" opacity="${isSel?1:0.88}"
      ${dash} ${marker} stroke-linecap="round" pointer-events="none"/>`;

    /* selection highlight */
    if(isSel) {
      out+=`<line x1="${p1.x}" y1="${p1.y}" x2="${p2.x}" y2="${p2.y}"
        stroke="#fff" stroke-width="1" opacity="0.35" ${dash} pointer-events="none"/>`;
      /* drag handles */
      out+=`<circle cx="${p1.x}" cy="${p1.y}" r="${HANDLE_R}" fill="${l.color}" stroke="#fff" stroke-width="2"
        class="line-handle" data-line="${i}" data-end="start" style="cursor:move"/>`;
      out+=`<circle cx="${p2.x}" cy="${p2.y}" r="${HANDLE_R}" fill="${l.color}" stroke="#fff" stroke-width="2"
        class="line-handle" data-line="${i}" data-end="end" style="cursor:move"/>`;
      /* midpoint handle */
      const mx=(p1.x+p2.x)/2, my=(p1.y+p2.y)/2;
      out+=`<circle cx="${mx}" cy="${my}" r="${HANDLE_R-2}" fill="#fff" stroke="${l.color}" stroke-width="2"
        class="line-handle" data-line="${i}" data-end="mid" style="cursor:grab"/>`;
    }
  });

  /* preview while drawing */
  if(drawing && drawStartPct) {
    const p1=pctToXY({x:drawStartPct.x,y:drawStartPct.y},W,H);
    out+=`<circle cx="${p1.x}" cy="${p1.y}" r="4" fill="${activeDrawColor}" opacity="0.7"/>`;
  }

  svg.innerHTML=out;

  /* attach hit-area events */
  svg.querySelectorAll(".line-hit").forEach(el => {
    el.addEventListener("mousedown", lineHitDown);
  });
  svg.querySelectorAll(".line-handle").forEach(el => {
    el.addEventListener("mousedown", handleDown);
  });
}

/* click on line hit area */
function lineHitDown(e) {
  if(currentTool!=="select") return;
  e.preventDefault(); e.stopPropagation();
  const idx=parseInt(e.currentTarget.dataset.line);
  if(selectedLine===idx) { deselectLine(); return; }
  selectedLine=idx;
  renderSVG();
  showLineInfo();
}

/* drag handle */
function handleDown(e) {
  if(currentTool!=="select") return;
  e.preventDefault(); e.stopPropagation();
  const idx=parseInt(e.currentTarget.dataset.line);
  const endpoint=e.currentTarget.dataset.end;
  const pos=clientToSVG(e.clientX,e.clientY);
  const {W,H}=getSVGSize();
  dragLine={lineIdx:idx, endpoint, startX:pos.x, startY:pos.y,
    ox:drawLines[idx].x1, oy:drawLines[idx].y1,
    ox2:drawLines[idx].x2, oy2:drawLines[idx].y2 };
  document.addEventListener("mousemove",onDragHandle);
  document.addEventListener("mouseup",stopDragHandle);
}
function onDragHandle(e) {
  if(!dragLine) return;
  const pos=clientToSVG(e.clientX,e.clientY);
  const {W,H}=getSVGSize();
  const dx=pos.x-dragLine.startX, dy=pos.y-dragLine.startY;
  const l=drawLines[dragLine.lineIdx];
  if(dragLine.endpoint==="start") {
    const p=xyToPct(pos.x,pos.y,W,H); l.x1=p.x; l.y1=p.y;
  } else if(dragLine.endpoint==="end") {
    const p=xyToPct(pos.x,pos.y,W,H); l.x2=p.x; l.y2=p.y;
  } else { /* mid — move whole line */
    const dxp=dx/W*100, dyp=dy/H*100;
    l.x1=Math.max(0,Math.min(100,dragLine.ox+dxp));
    l.y1=Math.max(0,Math.min(100,dragLine.oy+dyp));
    l.x2=Math.max(0,Math.min(100,dragLine.ox2+dxp));
    l.y2=Math.max(0,Math.min(100,dragLine.oy2+dyp));
  }
  renderSVG();
}
function stopDragHandle() {
  dragLine=null;
  document.removeEventListener("mousemove",onDragHandle);
  document.removeEventListener("mouseup",stopDragHandle);
}

function deselectLine() { selectedLine=null; renderSVG(); hideLineInfo(); }
function showLineInfo() { document.getElementById("lineInfo").style.display="block"; }
function hideLineInfo() { document.getElementById("lineInfo").style.display="none"; }

/* ========== SVG MOUSE for DRAWING ========== */
function svgMouseDown(e) {
  if(currentTool==="select") return;
  if(e.target.classList.contains("line-hit")||e.target.classList.contains("line-handle")) return;
  e.preventDefault();
  const pos=clientToSVG(e.clientX,e.clientY);
  const {W,H}=getSVGSize();
  drawing=true;
  drawStartPct=xyToPct(pos.x,pos.y,W,H);
}
function svgMouseMove(e) {
  if(!drawing||!drawStartPct) return;
  const pos=clientToSVG(e.clientX,e.clientY);
  const {W,H}=getSVGSize();
  const endPct=xyToPct(pos.x,pos.y,W,H);
  /* render preview inside SVG */
  renderSVG();
  const svg=document.getElementById("arrowLayer");
  const p1=pctToXY(drawStartPct,W,H), p2=pctToXY(endPct,W,H);
  const ns="http://www.w3.org/2000/svg";
  const line=document.createElementNS(ns,"line");
  line.setAttribute("x1",p1.x); line.setAttribute("y1",p1.y);
  line.setAttribute("x2",p2.x); line.setAttribute("y2",p2.y);
  line.setAttribute("stroke",activeDrawColor); line.setAttribute("stroke-width","3.5");
  line.setAttribute("opacity","0.7"); line.setAttribute("stroke-linecap","round");
  if(currentTool==="line") line.setAttribute("stroke-dasharray","10,6");
  if(currentTool==="arrow") line.setAttribute("marker-end",`url(#ah-${activeDrawColor.replace('#','')})`)
  line.setAttribute("pointer-events","none");
  svg.appendChild(line);
}
function svgMouseUp(e) {
  if(!drawing||!drawStartPct) return;
  const pos=clientToSVG(e.clientX,e.clientY);
  const {W,H}=getSVGSize();
  const endPct=xyToPct(pos.x,pos.y,W,H);
  const dist=Math.hypot((endPct.x-drawStartPct.x)/100*W,(endPct.y-drawStartPct.y)/100*H);
  if(dist>10) {
    drawLines.push({type:currentTool,x1:drawStartPct.x,y1:drawStartPct.y,x2:endPct.x,y2:endPct.y,color:activeDrawColor});
  }
  drawing=false; drawStartPct=null;
  renderSVG();
}

/* ========== DELETE SELECTED ========== */
function deleteSelected() {
  if(selectedLine!==null) {
    drawLines.splice(selectedLine,1);
    selectedLine=null; hideLineInfo();
    renderSVG();
  } else {
    if(confirm("Clear all drawings?")) { drawLines=[]; renderSVG(); }
  }
}

/* ========== PLANS ========== */
function savePlan() {
  const name=document.getElementById("planNameInput").value.trim(); if(!name) return;
  plans[name]={map:currentMap,positions:parties.map(p=>([p.x,p.y])),
    names:parties.map(p=>p.name),roles:parties.map(p=>p.role),
    notes:parties.map(p=>p.note),members:parties.map(p=>[...p.members]),
    lines:[...drawLines],battleNotes:document.getElementById("battleNotes").value};
  document.getElementById("planNameInput").value="";
  renderSavedPlans();
}
function loadPlan(name) {
  const pl=plans[name]; if(!pl) return;
  if(pl.map!==currentMap) switchMap(pl.map);
  parties.forEach((p,i)=>{ [p.x,p.y]=pl.positions[i]; p.name=pl.names[i]; p.role=pl.roles[i]; p.note=pl.notes[i]; p.members=[...pl.members[i]]; });
  drawLines=[...pl.lines];
  document.getElementById("battleNotes").value=pl.battleNotes||"";
  renderSidebar(); renderLegend(); renderTokens(); renderSVG();
}
function deletePlan(name) { delete plans[name]; renderSavedPlans(); }
function renderSavedPlans() {
  const el=document.getElementById("savedPlans"), keys=Object.keys(plans);
  el.innerHTML=keys.length===0?`<div style="font-size:10px;color:#2a2040;font-style:italic;padding:4px">No plans saved yet</div>`
    :keys.map(k=>`<div class="plan-item"><span class="plan-item-name" onclick="loadPlan('${k}')">${k}</span><span class="plan-del" onclick="deletePlan('${k}')">✕</span></div>`).join("");
}

function resetPositions() {
  const pos=currentMap==="stellar"?STELLAR_POS:VALE_POS;
  parties.forEach((p,i)=>{p.x=pos[i].x;p.y=pos[i].y;});
  renderTokens();
}
function clearAll() {
  if(!confirm("Clear all drawings and reset positions?")) return;
  resetPositions(); drawLines=[]; selectedLine=null; renderSVG();
  document.getElementById("battleNotes").value="";
}
function exportPlan() {
  const notes=document.getElementById("battleNotes").value;
  const lines=["╔═══════════════════════════════╗","║   GUILD WAR BATTLE PLAN       ║","╚═══════════════════════════════╝",
    `Map: ${currentMap==="stellar"?"Stellar Clash":"Vale of Clash"}`,""
  ];
  parties.forEach(p=>{
    lines.push(`[P${p.id}] ${p.name}  (${p.role})`);
    if(p.note) lines.push(`  Objective: ${p.note}`);
    const mems=p.members.filter(m=>m.trim());
    if(mems.length) lines.push(`  Members: ${mems.join(", ")}`);
    lines.push(`  Position: ${Math.round(p.x)}% x ${Math.round(p.y)}%`); lines.push("");
  });
  if(notes){ lines.push("BATTLE NOTES:"); lines.push(notes); }
  const blob=new Blob([lines.join("\n")],{type:"text/plain"});
  const a=document.createElement("a"); a.href=URL.createObjectURL(blob);
  a.download=`guild_war_plan_${Date.now()}.txt`; a.click();
}

/* ========== INIT ========== */
window.addEventListener("load",()=>{
  document.getElementById("mapImg").src=STELLAR_IMG;
  renderColorPicker(); renderSidebar(); renderLegend(); renderObjects(); renderTokens(); renderSavedPlans();
  setTool("select");
  setTimeout(renderSVG, 100);
});
window.addEventListener("resize",()=>{ renderTokens(); renderSVG(); });
</script>
